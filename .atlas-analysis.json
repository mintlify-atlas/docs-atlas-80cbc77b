  "keyFeatures": [
    "Docker-based server isolation and resource management",
    "Built-in SFTP server with Panel authentication",
    "RESTful HTTP API for server lifecycle management",
    "Real-time WebSocket console streaming",
    "Automated backup creation and restoration",
    "Server transfer capabilities between nodes",
    "Comprehensive file management operations",
    "Power action control (start, stop, restart, kill)",
    "Resource monitoring and statistics",
    "TLS/SSL support with Let's Encrypt integration",
    "Configuration file parsing and validation",
    "Crash detection and automatic recovery"
  ],
  "publicApiSurface": [
    "GET /api/system - System information",
    "GET /api/servers - List all servers",
    "POST /api/servers - Create server",
    "GET /api/servers/:server - Server details",
    "DELETE /api/servers/:server - Delete server",
    "POST /api/servers/:server/power - Power actions",
    "POST /api/servers/:server/commands - Send commands",
    "GET /api/servers/:server/logs - Get server logs",
    "GET /api/servers/:server/ws - WebSocket connection",
    "GET /api/servers/:server/files/list-directory - List files",
    "GET /api/servers/:server/files/contents - Read file",
    "POST /api/servers/:server/files/write - Write file",
    "POST /api/servers/:server/files/delete - Delete files",
    "POST /api/servers/:server/files/compress - Compress files",
    "POST /api/servers/:server/files/decompress - Decompress archive",
    "POST /api/servers/:server/files/chmod - Change permissions",
    "POST /api/servers/:server/files/pull - Remote file download",
    "POST /api/servers/:server/backup - Create backup",
    "POST /api/servers/:server/backup/:backup/restore - Restore backup",
    "DELETE /api/servers/:server/backup/:backup - Delete backup",
    "POST /api/servers/:server/transfer - Initiate transfer",
    "DELETE /api/servers/:server/transfer - Cancel transfer",
    "POST /api/transfers - Accept incoming transfer",
    "GET /download/backup - Download backup (signed URL)",
    "GET /download/file - Download file (signed URL)",
    "POST /upload/file - Upload file (signed URL)",
    "SFTP Server - Port 2022 (default)",
    "wings configure - Interactive configuration",
    "wings diagnostics - System diagnostics"
  ]
